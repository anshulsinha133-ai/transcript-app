// ─── Main TemplateNotes component ────────────────────────────────────────────
const TemplateNotes = ({ summary, mode }) => {
  const cfg = TEMPLATE_CONFIG[mode] || TEMPLATE_CONFIG.default;

  // Parse the summary JSON string (stored in Supabase as string)
  const data = useMemo(() => {
    if (!summary) return null;
    if (typeof summary === 'object') return summary; // already parsed
    try {
      const clean = summary
        .replace(/^```json\s*/i, '')
        .replace(/^```\s*/i, '')
        .replace(/\s*```$/i, '')
        .trim();
      return JSON.parse(clean);
    } catch {
      return null; // non-JSON (old-style plain text) — caller handles fallback
    }
  }, [summary]);

  if (!data) return null; // let TranscriptScreen render plain text fallback

  return (
    <View style={styles.container}>
      {/* Template badge */}
      <View style={[styles.badge, { backgroundColor: cfg.bg, borderColor: cfg.border }]}>
        <Text style={styles.badgeIcon}>{cfg.icon}</Text>
        <Text style={[styles.badgeLabel, { color: cfg.color }]}>{cfg.label}</Text>
      </View>

      {/* One-line summary */}
      {data.summary && (
        <View style={[styles.summaryBox, { borderLeftColor: cfg.color }]}>
          <Text style={styles.summaryText}>{data.summary}</Text>
        </View>
      )}

      {/* Template-specific fields */}
      {mode === 'meeting'   && <MeetingNotes   data={data} cfg={cfg} />}
      {mode === 'sales'     && <SalesNotes     data={data} cfg={cfg} />}
      {mode === 'lecture'   && <LectureNotes   data={data} cfg={cfg} />}
      {mode === 'doctor'    && <DoctorNotes    data={data} cfg={cfg} />}
      {mode === 'legal'     && <LegalNotes     data={data} cfg={cfg} />}
      {mode === 'interview' && <InterviewNotes data={data} cfg={cfg} />}
      {(!mode || mode === 'en' || mode === 'hi' || mode === 'mr') && (
        <DefaultNotes data={data} cfg={cfg} />
      )}
    </View>
  );
};

